      <span class="r-num">${p.num}</span>${p.title}
      <span class="r-tags">${p.tags.join(' · ')}</span>
    </button>`).join('');
}

function loadProj(i){
  cur=i; curTab=0;
  document.querySelectorAll('.r-btn').forEach((b,j)=>b.classList.toggle('active',j===i));
  renderMain();
}

function switchTab(i){
  curTab=i;
  document.querySelectorAll('.tab').forEach((t,j)=>t.classList.toggle('on',j===i));
  document.querySelectorAll('.tc').forEach((c,j)=>c.classList.toggle('on',j===i));
}

